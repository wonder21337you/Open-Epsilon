{
  "schemaVersion": 1,
  "id": "offlinemodefix",
  "version": "1.0.0",
  "name": "Offline Mode Fix",
  "description": "Fixes chat lag spikes, removes 'Not Secure' indicators, and suppresses unverified server warnings on offline-mode servers.",
  "authors": [
    "Louiszn"
  ],
  "contact": {
    "homepage": "https://github.com/louiszn/offline-mode-fix#readme",
    "sources": "https://github.com/louiszn/offline-mode-fix",
    "issues": "https://github.com/louiszn/offline-mode-fix/issues"
  },
  "entrypoints": {
    "epsilon:addon": [
      "com.github.epsilon.fabric.addon.FabricSelfAddonEntrypoint"
    ]
  },
  "license": "MIT",
  "icon": "assets/offlinemodefix/icon.png",
  "environment": "*",
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "minecraft": "~${minecraft_version}",
        "java": ">=${java_version}"
    }
}
