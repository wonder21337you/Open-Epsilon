{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "Open Epsilon - A Minecraft client mod",
    "authors": [
        "${mod_author}"
    ],
    "license": "${license}",
    "icon": "${mod_id}.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "com.github.epsilon.fabric.EpsilonFabric"
        ],
        "open_epsilon:addon": [
            "com.github.epsilon.fabric.addon.FabricSelfAddonEntrypoint"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "minecraft": "~${minecraft_version}",
        "java": ">=${java_version}"
    }
}
